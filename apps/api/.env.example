# ---- App ----
ENVIRONMENT=local
DEBUG=true

# ---- Database (async for app, sync for Alembic) ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_ad_platform
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@db:5432/ai_ad_platform

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Security (use AWS Secrets Manager in prod) ----
JWT_SECRET=change-me
SEED_ADMIN_EMAIL=admin@nolbal.com
SEED_ADMIN_PASSWORD=ChangeMe!234

# ---- External AI / Search (optional; loaded from Secrets Manager in prod) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
WEBSEARCH_API_KEY=
